<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>訪客登記</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: "Microsoft JhengHei", sans-serif;
      background: #f0f4f8;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      padding: 20px;
    }
    .card {
      background: white;
      border-radius: 12px;
      padding: 36px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }
    h1 { font-size: 22px; color: #1a1a2e; margin-bottom: 8px; }
    p { color: #666; font-size: 14px; margin-bottom: 28px; }
    label { display: block; font-size: 14px; color: #444; margin-bottom: 6px; font-weight: 600; }
    input, textarea {
      width: 100%;
      padding: 10px 14px;
      border: 1.5px solid #ddd;
      border-radius: 8px;
      font-size: 15px;
      margin-bottom: 20px;
      font-family: inherit;
    }
    input:focus, textarea:focus { outline: none; border-color: #4f46e5; }
    textarea { height: 90px; resize: vertical; }
    button {
      width: 100%;
      padding: 13px;
      background: #4f46e5;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
    }
    button:disabled { background: #a5b4fc; cursor: not-allowed; }
    #success { display: none; text-align: center; padding: 20px; color: #16a34a; font-size: 18px; font-weight: 600; }
  </style>
</head>
<body>
  <div class="card">
    <h1>👋 訪客登記</h1>
    <p>請填寫以下資料，接待人員將盡快與您聯繫。</p>
    <div id="form">
      <label>姓名 *</label>
      <input type="text" id="name" placeholder="請輸入您的姓名">
      <label>公司／單位 *</label>
      <input type="text" id="company" placeholder="請輸入公司名稱">
      <label>來訪目的 *</label>
      <textarea id="purpose" placeholder="請簡述來訪目的"></textarea>
      <button id="btn" onclick="submitForm()">送出登記</button>
    </div>
    <div id="success">
      ✅ 登記成功！<br>
      <span style="font-size:14px; color:#555; font-weight:normal;">謝謝您的登記。</span>
    </div>
  </div>
<script>
  const GAS_URL = "https://script.google.com/macros/s/AKfycbwANILDX555naUYI42C5WL_GUlz3LjtvmfYTy_m0jbjB4ny-iPqWAkcZblzHWsguhEmgQ/exec";

  async function submitForm() {
    const name = document.getElementById('name').value.trim();
    const company = document.getElementById('company').value.trim();
    const purpose = document.getElementById('purpose').value.trim();

    if (!name || !company || !purpose) {
      alert('請填寫所有欄位');
      return;
    }

    const btn = document.getElementById('btn');
    btn.disabled = true;
    btn.textContent = '送出中...';

    const params = new URLSearchParams({ name, company, purpose });

    try {
      await fetch(GAS_URL + '?' + params.toString(), {
        method: 'GET',
        mode: 'no-cors'
      });
      document.getElementById('form').style.display = 'none';
      document.getElementById('success').style.display = 'block';
    } catch (err) {
      alert('送出失敗，請重試');
      btn.disabled = false;
      btn.textContent = '送出登記';
    }
  }
</script>
</body>
</html>
